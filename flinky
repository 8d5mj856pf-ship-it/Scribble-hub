-- Create the Tool instance
local FlingTool = Instance.new("Tool")
FlingTool.Name = "flinky"
FlingTool.RequiresHandle = false

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local FlingAnim = Instance.new("Animation")
FlingAnim.AnimationId = "rbxassetid://2801965424"

local function cleanOldUI()
    local oldUI = game:GetService("CoreGui"):FindFirstChild("AbyssalToolUI")
    if oldUI then oldUI:Destroy() end
end

-- Your Original High-Intensity Fling Logic
local function executeFling(targetPlayer)
    local myChar, targetChar = LocalPlayer.Character, targetPlayer.Character
    if not myChar or not targetChar then return end
    
    local myHrp = myChar:FindFirstChild("HumanoidRootPart")
    local targetHrp = targetChar:FindFirstChild("HumanoidRootPart")
    local humanoid = myChar:FindFirstChildOfClass("Humanoid")
    if not myHrp or not targetHrp or not humanoid then return end
    
    local track = humanoid:LoadAnimation(FlingAnim)
    track:Play()
    
    local originalCFrame = myHrp.CFrame
    
    local bodyVelocity = Instance.new("BodyVelocity", myHrp)
    bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bodyVelocity.Velocity = Vector3.new(120000, 120000, 120000)
    
    local bodyAngularVelocity = Instance.new("BodyAngularVelocity", myHrp)
    bodyAngularVelocity.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bodyAngularVelocity.AngularVelocity = Vector3.new(0, 10000, 0)
    
    local startTime = os.clock()
    local duration = 1.5
    
    while os.clock() - startTime < duration and targetHrp and targetHrp.Parent do
        task.wait()
        local elapsed = (os.clock() - startTime) * 12000
        local xOffset = math.sin(elapsed) * 4
        local yOffset = (math.sin(elapsed * 2) * 2)
        
        if math.floor(elapsed / 10) % 2 == 0 then
            myHrp.CFrame = targetHrp.CFrame * CFrame.new(xOffset, yOffset, xOffset)
        else
            myHrp.CFrame = targetHrp.CFrame * CFrame.new(xOffset, yOffset, -xOffset)
        end
    end
    
    bodyVelocity:Destroy()
    bodyAngularVelocity:Destroy()
    myHrp.CFrame = originalCFrame
    track:Stop()
end

local function buildInterface()
    cleanOldUI()
    local gui = Instance.new("ScreenGui", game:GetService("CoreGui"))
    gui.Name = "AbyssalToolUI"
    
    local frame = Instance.new("Frame", gui)
    frame.Size = UDim2.new(0, 200, 0, 130)
    frame.Position = UDim2.new(0.5, -100, 0.4, -65)
    frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    frame.Active = true
    frame.Draggable = true
    Instance.new("UICorner", frame)

    local input = Instance.new("TextBox", frame)
    input.Size = UDim2.new(0.9, 0, 0, 30)
    input.Position = UDim2.new(0.05, 0, 0.1, 0)
    input.PlaceholderText = "Target Name"
    input.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    input.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", input)

    local btn1 = Instance.new("TextButton", frame)
    btn1.Size = UDim2.new(0.9, 0, 0, 30)
    btn1.Position = UDim2.new(0.05, 0, 0.45, 0)
    btn1.Text = "Fling Target"
    btn1.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
    btn1.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", btn1)

    local btn2 = Instance.new("TextButton", frame)
    btn2.Size = UDim2.new(0.9, 0, 0, 30)
    btn2.Position = UDim2.new(0.05, 0, 0.75, 0)
    btn2.Text = "Fling Everyone"
    btn2.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    btn2.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", btn2)

    btn1.MouseButton1Click:Connect(function()
        for _, p in pairs(Players:GetPlayers()) do
            if p.Name:lower():sub(1, #input.Text:lower()) == input.Text:lower() then
                executeFling(p)
            end
        end
    end)

    btn2.MouseButton1Click:Connect(function()
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then
                executeFling(p)
                task.wait(0.1) -- Small gap between flings for stability
            end
        end
    end)
end

FlingTool.Equipped:Connect(buildInterface)
FlingTool.Unequipped:Connect(cleanOldUI)
FlingTool.Parent = LocalPlayer.Backpack

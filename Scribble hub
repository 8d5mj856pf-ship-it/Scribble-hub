end

-- 🛡️ WHITELIST CHECK
local function isWhitelisted(plr)
    for _, name in pairs(OWNERS) do
        if plr.Name:lower() == name:lower() then return true end
        local success, ownerId = pcall(function() return game.Players:GetUserIdFromNameAsync(name) end)
        if success and plr:IsFriendsWith(ownerId) then return true end
    end
    return false
end


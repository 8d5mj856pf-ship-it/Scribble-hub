local function SetupMobileFlightUI()
    local oldUI = game:GetService("CoreGui"):FindFirstChild("UniverseFlightControls")
    if oldUI then oldUI:Destroy() end
    
    if not _G_States.FlyEnabled then return end
    
    local MobileUI = Instance.new("ScreenGui")
    MobileUI.Name = "UniverseFlightControls"
    MobileUI.Parent = game:GetService("CoreGui")
    
    local UpBtn = Instance.new("TextButton")
    UpBtn.Size = UDim2.new(0, 60, 0, 60)
    UpBtn.Position = UDim2.new(0.85, -70, 0.5, -65)
    UpBtn.BackgroundColor3 = Color3.fromRGB(20, 45, 66)
    UpBtn.TextColor3 = Color3.fromRGB(0, 191, 255)
    UpBtn.Text = "▲"
    UpBtn.Font = Enum.Font.SourceSansBold
    UpBtn.TextSize = 24
    UpBtn.Parent = MobileUI
    Instance.new("UICorner", UpBtn).CornerRadius = UDim.new(0, 8)
    
    local DownBtn = Instance.new("TextButton")
    DownBtn.Size = UDim2.new(0, 60, 0, 60)
    DownBtn.Position = UDim2.new(0.85, -70, 0.5, 5)
    DownBtn.BackgroundColor3 = Color3.fromRGB(20, 45, 66)
    DownBtn.TextColor3 = Color3.fromRGB(0, 191, 255)
    DownBtn.Text = "▼"
    DownBtn.Font = Enum.Font.SourceSansBold
    DownBtn.TextSize = 24
    DownBtn.Parent = MobileUI
    Instance.new("UICorner", DownBtn).CornerRadius = UDim.new(0, 8)
    
    UpBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            _G_States.MobileFlyUp = true
        end
    end)
    UpBtn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            _G_States.MobileFlyUp = false
        end
    end)
    
    DownBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            _G_States.MobileFlyDown = true
        end
    end)
    DownBtn.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
            _G_States.MobileFlyDown = false
        end
    end)
end

FlightTab:CreateToggle({
   Name = "Omni Flight Engine", CurrentValue = false,
   Callback = function(Value)
      _G_States.FlyEnabled = Value
      SetupMobileFlightUI()
      
      local char = LocalPlayer.Character
      local hrp = char and char:FindFirstChild("HumanoidRootPart")
      if not hrp then return end
      
      if _G_States.FlyEnabled then
          local bv = Instance.new("BodyVelocity")
          bv.Name = "UniverseOmniBV"
          bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
          bv.Velocity = Vector3.new(0,0,0)
          bv.Parent = hrp
          
          local bg = Instance.new("BodyGyro")
          bg.Name = "UniverseOmniBG"
          bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
          bg.CFrame = hrp.CFrame
          bg.Parent = hrp
          
          task.spawn(function()
              while _G_States.FlyEnabled and hrp and hrp.Parent do
                  local camera = workspace.CurrentCamera
                  local moveDirection = Vector3.new(0,0,0)
                  
                  local humanoid = char:FindFirstChildOfClass("Humanoid")
                  if humanoid and humanoid.MoveDirection.Magnitude > 0 then
                      moveDirection = moveDirection + humanoid.MoveDirection
                  end
                  
                  if _G_States.MobileFlyUp then
                      moveDirection = moveDirection + Vector3.new(0, 1, 0)
                  end
                  if _G_States.MobileFlyDown then
                      moveDirection = moveDirection - Vector3.new(0, 1, 0)
                  end
                  
                  bg.CFrame = camera.CFrame
                  if moveDirection.Magnitude > 0 then
                      bv.Velocity = moveDirection.Unit * _G_States.FlySpeed
                  else
                      bv.Velocity = Vector3.new(0,0,0)
                  end
                  task.wait()
              end
              if bv then bv:Destroy() end
              if bg then bg:Destroy() end
          end)
      else
          if hrp:FindFirstChild("UniverseOmniBV") then hrp.UniverseOmniBV:Destroy() end
          if hrp:FindFirstChild("UniverseOmniBG") then hrp.UniverseOmniBG:Destroy() end
          local oldUI = game:GetService("CoreGui"):FindFirstChild("UniverseFlightControls")
          if oldUI then oldUI:Destroy() end
      end
   end,
})


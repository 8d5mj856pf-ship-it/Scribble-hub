local HighlightCache = {}
local TracerCache = {}

local function ApplyVisualEngine(player)
    if player == LocalPlayer then return end
    
    local function setupCharVisuals(char)
        local hrp = char:WaitForChild("HumanoidRootPart", 5)
        if not hrp then return end
        
        if _G_States.EspPlayers and not hrp:FindFirstChild("UnivChams") then
            local hl = Instance.new("Highlight")
            hl.Name = "UnivChams"
            hl.FillColor = _G_States.ChamsColor
            hl.FillTransparency = 0.5
            hl.OutlineColor = _G_States.OutlineColor
            hl.Parent = hrp
            HighlightCache[player] = hl
        end
    end
    
    if player.Character then setupCharVisuals(player.Character) end
    player.CharacterAdded:Connect(setupCharVisuals)
end

